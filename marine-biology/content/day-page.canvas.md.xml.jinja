{% set days = load('days.yaml') %}
{% for day in days %}
<page title="Day {{ day.num }}: {{ day.title }}" id="day{{ day.num }}-{{ day.id_slug }}">

## {{ day.title }}

{{ day.intro }}

### Topics

{% for topic in day.topics %}
- **{{ topic.name }}** — {{ topic.description }}
{% endfor %}

### Key Questions

{% for q in day.questions %}
{{ loop.index }}. {{ q }}
{% endfor %}

{% if day.activity is defined %}
### Activity

{{ day.activity }}
{% endif %}

{% if day.note is defined %}
---

{{ day.note }}
{% endif %}

</page>
{% endfor %}
