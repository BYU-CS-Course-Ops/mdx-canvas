<div>
    <course-settings
            name="Introduction to Marine Biology — {{ term }} {{ year }}"
            code="MBIO 101"
    />

    <assignment-groups>
        <group name="Participation" weight="{{ Group_Weights.Participation }}"/>
        <group name="Lab Notebook" weight="{{ Group_Weights['Lab Notebook'] }}"/>
        <group name="Quizzes" weight="{{ Group_Weights.Quizzes }}"/>
        <group name="Presentations" weight="{{ Group_Weights.Presentations }}"/>
        <group name="Essays" weight="{{ Group_Weights.Essays }}"/>
    </assignment-groups>

    <!-- ── Assessments ─────────────────────────────────── -->
    <include path="content/assessments/midweek-quiz.canvas.md.xml"/>
    <include path="content/assessments/lab-notebook.canvas.md.xml"/>
    <include path="content/assessments/group-presentation.canvas.md.xml"/>
    <include path="content/assessments/final-reflection-essay.canvas.md.xml"/>

    <!-- ── Day Pages (generated from Jinja template) ─────── -->
    <include path="content/day-page.canvas.md.xml.jinja"/>

    <!-- ══ Modules ═══════════════════════════════════════ -->

    <module id="unit1-foundations" title="Unit 1: Foundations of the Ocean">
        <item type="page" content_id="day1-welcome" title="Day 1: Welcome to the Sea" indent="1"
              completion_requirement="type=must_view"/>
        <item type="page" content_id="day2-ocean-geography" title="Day 2: Ocean Geography" indent="1"
              completion_requirement="type=must_view"/>
        <item type="page" content_id="day3-seawater-chemistry" title="Day 3: Seawater Chemistry" indent="1"
              completion_requirement="type=must_view"/>
    </module>

    <module id="unit2-open-water" title="Unit 2: Life in the Open Water"
            prerequisite_module_ids="unit1-foundations">
        <item type="page" content_id="day4-phytoplankton" title="Day 4: Phytoplankton &amp; Primary Production"
              indent="1" completion_requirement="type=must_view"/>
        <item type="page" content_id="day5-zooplankton" title="Day 5: Zooplankton &amp; Food Webs" indent="1"
              completion_requirement="type=must_view"/>
        <item type="quiz" content_id="midweek-quiz" title="Midweek Quiz: Units 1 &amp; 2" indent="1"
              completion_requirement="type=must_submit"/>
    </module>

    <module id="unit3-coastal" title="Unit 3: Coastal &amp; Benthic Ecosystems"
            prerequisite_module_ids="unit2-open-water">
        <item type="page" content_id="day6-coral-reefs" title="Day 6: Coral Reefs" indent="1"
              completion_requirement="type=must_view"/>
        <item type="page" content_id="day7-estuaries-mangroves" title="Day 7: Estuaries &amp; Mangroves" indent="1"
              completion_requirement="type=must_view"/>
        <item type="page" content_id="day8-deep-sea" title="Day 8: The Deep Sea" indent="1"
              completion_requirement="type=must_view"/>
    </module>

    <module id="unit4-megafauna" title="Unit 4: Marine Megafauna &amp; Conservation"
            prerequisite_module_ids="unit3-coastal">
        <item type="page" content_id="day9-marine-mammals" title="Day 9: Marine Mammals" indent="1"
              completion_requirement="type=must_view"/>
        <item type="assignment" content_id="group-presentation" title="Group Presentation" indent="1"
              completion_requirement="type=must_submit"/>
        <item type="page" content_id="day10-sharks-rays-turtles" title="Day 10: Sharks, Rays &amp; Sea Turtles"
              indent="1" completion_requirement="type=must_view"/>
        <item type="assignment" content_id="final-reflection-essay" title="Final Reflection Essay" indent="1"
              completion_requirement="type=must_submit"/>
    </module>

    <module id="assessments-module" title="Assessments">
        <item type="assignment" content_id="lab-notebook" title="Lab Notebook" indent="1"
              completion_requirement="type=must_submit"/>
        <item type="quiz" content_id="midweek-quiz" title="Midweek Quiz: Units 1 &amp; 2" indent="1"
              completion_requirement="type=must_submit"/>
        <item type="assignment" content_id="group-presentation" title="Group Presentation" indent="1"
              completion_requirement="type=must_submit"/>
        <item type="assignment" content_id="final-reflection-essay" title="Final Reflection Essay" indent="1"
              completion_requirement="type=must_submit"/>
    </module>

</div>
