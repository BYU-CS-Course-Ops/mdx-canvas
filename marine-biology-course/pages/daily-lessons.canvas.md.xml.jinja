{% for day in args %}
<page id="{{ day.id }}" title="{{ day.title }}">
# {{ day.title }}

## Focus

{{ day.focus }}

## Learning Objectives

{% for objective in day.learning_objectives %}
- {{ objective }}
{% endfor %}

## Core Topics

{% for topic in day.core_topics %}
### {{ topic.heading }}

{{ topic.body }}

{% endfor %}
## Applied Activity

{{ day.applied_activity_intro }}

{% if day.applied_activity_bullets %}
{% for bullet in day.applied_activity_bullets %}
- {{ bullet }}
{% endfor %}
{% endif %}

## {{ day.closing_heading }}

{{ day.closing_text }}
</page>

{% endfor %}
